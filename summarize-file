import os
import sys
from datetime import datetime
from pathlib import Path
from typing import Optional

import markitdown
from markitdown import MarkItDown
from openai import OpenAI

MODEL = "gpt-5.4"

LLM_CLIENT = OpenAI()


PROMPTS = {
    "default": """Summarise this file in Markdown.

Return exactly these sections:

# Summary
Very brief bullet point summary of the file. Never more than necessary. If there is only one important thing, just say that. Follow the MECE (Mutually Exclusive, Collectively Exhaustive) Framework.

# Key details
Important facts, decisions, names, dates, methods, or structure. If there are any contrasting opinions, make those explicit. Follow the MECE Framework.

# Open questions
Anything unclear, missing, or worth checking.

# Input
Filename: {filename}
Timestamp: {timestamp}


Document content:
{text}/
"""
}


def get_stream_info(path: Path) -> Optional[markitdown.StreamInfo]:
    txt_extensions = [
        ".txt",
        ".text",
        ".md",
        ".markdown",
        ".json",
        ".jsonl",
    ]

    if path.suffix.lower() in txt_extensions:
        return markitdown.StreamInfo(charset="utf-8")
    else:
        return None


def convert_to_markdown(path: Path) -> str:
    md = MarkItDown(
        enable_builtins=True,
        enable_plugins=True,
        llm_client=LLM_CLIENT,
        model=MODEL,
    )
    result = md.convert(str(path), stream_info=get_stream_info(path))
    text = getattr(result, "text_content", None) or str(result)
    return text.strip()


def summarise_text(filename: str, text: str) -> str:
    if len(text) > 120_000:
        text = text[:120_000] + "\n\n[Truncated before upload]"

    prompt = pick_prompt(text)
    response = LLM_CLIENT.responses.create(
        model=MODEL,
        input=prompt.format(filename=filename, text=text, timestamp=datetime.now().isoformat()),
    )
    return response.output_text.strip()


def pick_prompt(text: str) -> str:
    return PROMPTS["default"]


def process_file(path_str: str) -> None:
    path = Path(path_str).expanduser().resolve()

    if not path.is_file():
        print(f"Skipping non-file: {path}", file=sys.stderr)
        return

    markdown = convert_to_markdown(path)
    if not markdown:
        raise RuntimeError(f"No extractable content for {path.name}")

    contents_path = path.with_name(f".{path.name}.contents.md")
    contents_path.write_text(markdown + "\n", encoding="utf-8")
    print(f"Wrote {contents_path}")

    summary = summarise_text(path.name, markdown)
    out_path = path.with_name(path.name + ".summary.md")
    out_path.write_text(summary + "\n", encoding="utf-8")
    print(f"Wrote {out_path}")


def main() -> int:
    if "OPENAI_API_KEY" not in os.environ:
        print("OPENAI_API_KEY is not set", file=sys.stderr)
        return 2

    if len(sys.argv) < 2:
        print("Usage: file_summary.py <file1> [file2 ...]", file=sys.stderr)
        return 1

    rc = 0
    for arg in sys.argv[1:]:
        try:
            process_file(arg)
        except Exception as e:
            rc = 1
            print(f"Failed: {arg}: {e}", file=sys.stderr)
    return rc


if __name__ == "__main__":
    raise SystemExit(main())
